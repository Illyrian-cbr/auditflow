# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# QuickBooks (Phase 3 — scaffolded, needs developer account)
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret

# Xero (Phase 3 — scaffolded, needs developer account)
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret

# Integration Token Encryption (32-byte hex key for AES-256-GCM)
INTEGRATION_ENCRYPTION_KEY=your_64_char_hex_string_here
