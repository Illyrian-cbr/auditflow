STRIPE_STARTER_PRICE_ID=your_stripe_starter_price_id
STRIPE_PRO_PRICE_ID=your_stripe_pro_price_id
STRIPE_PERSONAL_PRICE_ID=your_stripe_personal_price_id
STRIPE_TEAM_STARTER_PRICE_ID=your_stripe_team_starter_price_id
STRIPE_TEAM_PRO_PRICE_ID=your_stripe_team_pro_price_id
STRIPE_WHITE_LABEL_PRICE_ID=your_stripe_white_label_price_id
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=your_stripe_starter_price_id
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=your_stripe_pro_price_id
NEXT_PUBLIC_STRIPE_PERSONAL_PRICE_ID=your_stripe_personal_price_id
NEXT_PUBLIC_STRIPE_TEAM_STARTER_PRICE_ID=your_stripe_team_starter_price_id
